---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, pages, ui, type Lang } from "../../data/site";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const page = pages[lang].home;
const t = ui[lang];
const narrativeLinks = [
  {
    href: `/${lang}/solutions/`,
    label: lang === "zh" ? "查看核心业务" : "View Solutions"
  },
  {
    href: `/${lang}/engineering/`,
    label: lang === "zh" ? "了解技术能力" : "Explore Engineering"
  },
  {
    href: `/${lang}/facilities/`,
    label: lang === "zh" ? "查看交付能力" : "View Delivery Capability"
  }
];
---

<BaseLayout lang={lang} pageKey="home" title={page.title} description={page.description}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <h1>{page.heroTitle}</h1>
        <div class="subtitle">{page.heroSubtitle}</div>
        <p>{page.heroBody}</p>
        <div class="cta-row">
          <a class="button primary" href={`/${lang}/solutions/`}>{t.ctaPrimary}</a>
          <a class="button secondary" href={`/${lang}/contact/`}>{t.ctaContact}</a>
        </div>
      </div>
      <figure class="media-frame hero-media">
        <img src={assets.homeHero} alt={lang === "zh" ? "自动化测试设备现场" : "Automated testing equipment on the production floor"} />
      </figure>
    </div>
    <div class="stat-rail">
      {page.stats.map(([value, label]) => (
        <div class="stat">
          <strong>{value}</strong>
          <span>{label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section section-narrative">
    <div class="container">
      {page.sections.map((item, index) => (
        <div class:list={["narrative-row", { "row-reverse": index % 2 === 1 }]}>
          <div class="narrative-content">
            <span class="sequence-mark"><strong>{String(index + 1).padStart(2, "0")}</strong></span>
            <h2>{item.title}</h2>
            <p class="lead">{item.body}</p>
            <a class="text-link" href={narrativeLinks[index].href}>{narrativeLinks[index].label}</a>
          </div>
          {index === 0 ? (
            <div class="process-mosaic" aria-label={item.title}>
              {assets.processImages.map((src, imageIndex) => (
                <figure class={`mosaic-tile tile-${imageIndex + 1}`}>
                  <img src={src} alt={`${item.title} ${imageIndex + 1}`} loading={imageIndex === 0 ? "eager" : "lazy"} />
                </figure>
              ))}
            </div>
          ) : (
            <figure class:list={["media-frame", "narrative-visual", { "global-map-visual": index === 2 }]}>
              <img
                src={index === 1 ? assets.engineering : assets.globalMap}
                alt={item.title}
                loading="lazy"
              />
            </figure>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="section alt">
    <div class="container split-trust">
      <div class="section-heading">
        <h2>{pages[lang].customers.heroTitle}</h2>
        <p class="lead">{pages[lang].customers.heroBody}</p>
        <div class="cta-row">
          <a class="button secondary" href={`/${lang}/customers/`}>{lang === "zh" ? "查看代表性项目" : "View Case Types"}</a>
        </div>
      </div>
      <div class="logo-wall-mini" aria-label={lang === "zh" ? "客户标识" : "Customer logos"}>
        {assets.customerLogos.slice(0, 8).map((src, index) => (
          <figure>
            <img src={src} alt={`Customer logo ${index + 1}`} loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container split">
      <div class="section-heading">
        <h2>{page.bottomCta[0]}</h2>
        <p class="lead">{page.bottomCta[1]}</p>
      </div>
      <div class="card">
        <h3>{lang === "zh" ? "项目沟通建议" : "Project Review Inputs"}</h3>
        <p>{lang === "zh" ? "请简述产品类型、当前工艺痛点、期望节拍（UPH）及交付周期，便于初步判断方案方向。" : "Share product type, current process pain points, target takt time (UPH), and expected timeline for an initial review."}</p>
        <div class="cta-row">
          <a class="button primary" href={`mailto:ronghao@jinxiangsz.com`}>{t.emailUs}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
